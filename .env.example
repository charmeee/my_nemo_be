# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# File Storage
FILE_UPLOAD_DIR=./data/uploads

# App
APP_FRONTEND_URL=http://localhost:5173
